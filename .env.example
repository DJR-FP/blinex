# Copy to .env and fill in values before running docker compose

# Management server
JWT_SECRET=change-me-to-a-random-32-char-string
MESHNET_DEFAULT_KEY=MESHNET-DEFAULT-KEY

# PostgreSQL
POSTGRES_PASSWORD=change-me-too

# Relay server — set to the public IP of your relay host
RELAY_PUBLIC_IP=1.2.3.4
RELAY_AUTH_PASS=change-me-also
