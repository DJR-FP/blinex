# Copy this file to .env and fill in the values before running docker compose up.

# ── Required ────────────────────────────────────────────────────────────────

# JWT signing secret — min 32 random characters
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# PostgreSQL password
POSTGRES_PASSWORD=change-me

# Public IP of the host running the relay server (used for STUN/TURN)
RELAY_PUBLIC_IP=1.2.3.4

# ── Setup key ────────────────────────────────────────────────────────────────

# Seed setup key — agents use this to enroll. A random key is generated on
# startup if this is not set, but it changes on every restart.
# Generate: openssl rand -hex 16 | sed 's/.\{8\}/&-/g;s/-$//'
BLINEX_DEFAULT_KEY=XXXXXXXX-XXXXXXXX-XXXXXXXX-XXXXXXXX

# ── Dashboard ────────────────────────────────────────────────────────────────

# Public URL of the management API, passed to the dashboard at build time.
# Set this to wherever your management API is reachable from the browser.
NEXT_PUBLIC_MGMT_API=https://localhost:8080

# ── Admin login ──────────────────────────────────────────────────────────────

# Dashboard admin credentials. Set MGMT_ADMIN_PASSWORD to enable admin login.
# Username defaults to "admin" if MGMT_ADMIN_USER is not set.
# MGMT_ADMIN_USER=admin
MGMT_ADMIN_PASSWORD=change-me

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated allowed origins for the management API.
# Set to your dashboard domain in production.
# Defaults to http://localhost:3000 if not set.
# MGMT_ALLOWED_ORIGINS=https://dashboard.example.com

# ── TURN relay credentials ────────────────────────────────────────────────────

# TURN long-term credential password. Change before exposing the relay publicly.
RELAY_AUTH_PASS=change-me

# ── TLS (optional) ───────────────────────────────────────────────────────────

# Paths to real TLS cert/key PEM files for the management and signal servers.
# Leave unset to use the auto-generated self-signed certificate.
# TLS_CERT_FILE=/etc/meshnet/server.crt
# TLS_KEY_FILE=/etc/meshnet/server.key
